{
  "name": "sidechick",
  "displayName": "Sidechick",
  "description": "Your coding challenge sidekick inside VS Code",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Other"
  ],
  "repository": {
    "url": "https://github.com/herin7/sidechick"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "publisher": "HerinSoni",
  "icon": "media/sidechick.png",
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "sidechick.startChallenge",
        "title": "Start Challenge",
        "category": "Sidechick",
        "icon": "$(beaker)"
      },
      {
        "command": "sidechick.signInWithGitHub",
        "title": "Sign In With GitHub",
        "category": "Sidechick",
        "icon": "$(github)"
      },
      {
        "command": "sidechick.loginLeetCode",
        "title": "Sign In to LeetCode",
        "category": "Sidechick",
        "icon": "$(key)"
      },
      {
        "command": "sidechick.continueAnonymously",
        "title": "Continue Anonymously",
        "category": "Sidechick",
        "icon": "$(person)"
      },
      {
        "command": "sidechick.startMernBugMode",
        "title": "Start MERN Bug Mode",
        "category": "Sidechick",
        "icon": "$(tools)"
      }
    ],
    "configuration": {
      "title": "Sidechick",
      "properties": {
        "sidechick.backendBaseUrl": {
          "type": "string",
          "default": "http://127.0.0.1:3000",
          "description": "Base URL for the Sidechick backend service."
        },
        "sidechick.mode": {
          "type": "string",
          "enum": [
            "dsa",
            "dev",
            "random"
          ],
          "default": "random",
          "description": "Default SideChick challenge mode used when AI interception fires."
        }
      }
    }
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "vscode-test",
    "build:webview": "cd webview-ui && npm run build",
    "vscode:prepublish": "npm run build:webview"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.100.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "axios": "^1.14.0",
    "uuid": "^11.1.0"
  }
}
